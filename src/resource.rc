#include <windows.h>
#include "resource.h"

IDD_CONFIG DIALOGEX 0, 0, 380, 440
STYLE WS_CAPTION | WS_SYSMENU | DS_MODALFRAME
EXSTYLE WS_EX_TOOLWINDOW
CAPTION "Aqua's Divine Subtitle Plugin — Settings"
FONT 9, "Segoe UI"
BEGIN
    // ================================================================
    // STT / ASR group
    // ================================================================
    GROUPBOX    "STT / ASR (Speech Recognition)", 301, 10, 8, 360, 80
    LTEXT       "API Base URL:", 401, 20, 28, 90, 12
    EDITTEXT    IDC_STT_API_BASE, 120, 26, 240, 14, ES_AUTOHSCROLL
    LTEXT       "API Key:", 402, 20, 48, 90, 12
    EDITTEXT    IDC_STT_API_KEY, 120, 46, 240, 14, ES_AUTOHSCROLL
    LTEXT       "Model:", 403, 20, 68, 90, 12
    EDITTEXT    IDC_STT_MODEL, 120, 66, 240, 14, ES_AUTOHSCROLL

    // ================================================================
    // Translation LLM group
    // ================================================================
    GROUPBOX    "Translation (LLM Chat Completions)", 302, 10, 98, 360, 178
    LTEXT       "API Base URL:", 404, 20, 118, 90, 12
    EDITTEXT    IDC_TRANSLATE_API_BASE, 120, 116, 240, 14, ES_AUTOHSCROLL
    LTEXT       "API Key:", 405, 20, 138, 90, 12
    EDITTEXT    IDC_TRANSLATE_API_KEY, 120, 136, 240, 14, ES_AUTOHSCROLL
    LTEXT       "Model:", 406, 20, 158, 90, 12
    EDITTEXT    IDC_TRANSLATE_MODEL, 120, 156, 240, 14, ES_AUTOHSCROLL
    LTEXT       "System Prompt (use ${TARGET_LANG} for language):", 407, 20, 178, 340, 12
    EDITTEXT    IDC_TRANSLATE_PROMPT, 20, 194, 340, 70, ES_MULTILINE | ES_AUTOVSCROLL | ES_WANTRETURN | WS_VSCROLL

    // ================================================================
    // General group
    // ================================================================
    GROUPBOX    "General", 303, 10, 286, 360, 92
    LTEXT       "Target Language:", 408, 20, 306, 90, 12
    EDITTEXT    IDC_TARGET_LANG, 120, 304, 240, 14, ES_AUTOHSCROLL
    LTEXT       "Offset (ms):", 409, 20, 326, 90, 12
    EDITTEXT    IDC_OFFSET_MS, 120, 324, 80, 14, ES_AUTOHSCROLL | ES_NUMBER
    CONTROL     "Enable Subtitle Processing", IDC_ENABLED, "Button",
                BS_AUTOCHECKBOX | WS_TABSTOP, 20, 348, 200, 14

    // ================================================================
    // Buttons
    // ================================================================
    DEFPUSHBUTTON "OK", IDOK, 220, 410, 70, 24
    PUSHBUTTON    "Cancel", IDCANCEL, 300, 410, 70, 24
END
