#include <windows.h>
#include "resource.h"

IDD_CONFIG DIALOGEX 0, 0, 520, 480
STYLE WS_CAPTION | WS_SYSMENU | WS_THICKFRAME | DS_MODALFRAME | DS_CENTER
EXSTYLE WS_EX_TOOLWINDOW
CAPTION "Aqua's Divine Subtitle Plugin — Settings"
FONT 9, "Segoe UI"
BEGIN
    // ================================================================
    // STT / ASR group
    // ================================================================
    GROUPBOX    "STT / ASR (Speech Recognition)", 301, 10, 8, 500, 90
    LTEXT       "API Base URL:", 401, 22, 28, 100, 12
    EDITTEXT    IDC_STT_API_BASE, 128, 26, 370, 14, ES_AUTOHSCROLL
    LTEXT       "API Key:", 402, 22, 48, 100, 12
    EDITTEXT    IDC_STT_API_KEY, 128, 46, 370, 14, ES_AUTOHSCROLL
    LTEXT       "Model:", 403, 22, 68, 100, 12
    EDITTEXT    IDC_STT_MODEL, 128, 66, 370, 14, ES_AUTOHSCROLL

    // ================================================================
    // Translation LLM group
    // ================================================================
    GROUPBOX    "Translation (LLM Chat Completions)", 302, 10, 108, 500, 198
    LTEXT       "API Base URL:", 404, 22, 128, 100, 12
    EDITTEXT    IDC_TRANSLATE_API_BASE, 128, 126, 370, 14, ES_AUTOHSCROLL
    LTEXT       "API Key:", 405, 22, 148, 100, 12
    EDITTEXT    IDC_TRANSLATE_API_KEY, 128, 146, 370, 14, ES_AUTOHSCROLL
    LTEXT       "Model:", 406, 22, 168, 100, 12
    EDITTEXT    IDC_TRANSLATE_MODEL, 128, 166, 370, 14, ES_AUTOHSCROLL
    LTEXT       "System Prompt (use ${TARGET_LANG} for language):", 407, 22, 192, 380, 12
    EDITTEXT    IDC_TRANSLATE_PROMPT, 22, 210, 478, 84, ES_MULTILINE | ES_AUTOVSCROLL | ES_WANTRETURN | WS_VSCROLL

    // ================================================================
    // General group
    // ================================================================
    GROUPBOX    "General", 303, 10, 316, 500, 100
    LTEXT       "Target Language:", 408, 22, 338, 100, 12
    EDITTEXT    IDC_TARGET_LANG, 128, 336, 200, 14, ES_AUTOHSCROLL
    LTEXT       "Offset (ms):", 409, 22, 360, 100, 12
    EDITTEXT    IDC_OFFSET_MS, 128, 358, 80, 14, ES_AUTOHSCROLL | ES_NUMBER
    CONTROL     "Enable Subtitle Processing", IDC_ENABLED, "Button",
                BS_AUTOCHECKBOX | WS_TABSTOP, 22, 386, 200, 14

    // ================================================================
    // Buttons
    // ================================================================
    DEFPUSHBUTTON "OK", IDOK, 195, 430, 80, 22
    PUSHBUTTON    "Cancel", IDCANCEL, 290, 430, 80, 22
END