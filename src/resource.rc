#include <windows.h>
#include "resource.h"

IDD_CONFIG DIALOGEX 0, 0, 480, 560
STYLE WS_CAPTION | WS_SYSMENU | WS_THICKFRAME | DS_MODALFRAME
EXSTYLE WS_EX_TOOLWINDOW
CAPTION "Aqua's Divine Subtitle Plugin — Settings"
FONT 9, "Segoe UI"
BEGIN
    // ================================================================
    // STT / ASR group
    // ================================================================
    GROUPBOX    "STT / ASR (Speech Recognition)", 301, 10, 8, 460, 84
    LTEXT       "API Base URL:", 401, 22, 28, 100, 12
    EDITTEXT    IDC_STT_API_BASE, 128, 26, 330, 14, ES_AUTOHSCROLL
    LTEXT       "API Key:", 402, 22, 48, 100, 12
    EDITTEXT    IDC_STT_API_KEY, 128, 46, 330, 14, ES_AUTOHSCROLL
    LTEXT       "Model:", 403, 22, 68, 100, 12
    EDITTEXT    IDC_STT_MODEL, 128, 66, 330, 14, ES_AUTOHSCROLL

    // ================================================================
    // Translation LLM group
    // ================================================================
    GROUPBOX    "Translation (LLM Chat Completions)", 302, 10, 102, 460, 188
    LTEXT       "API Base URL:", 404, 22, 122, 100, 12
    EDITTEXT    IDC_TRANSLATE_API_BASE, 128, 120, 330, 14, ES_AUTOHSCROLL
    LTEXT       "API Key:", 405, 22, 142, 100, 12
    EDITTEXT    IDC_TRANSLATE_API_KEY, 128, 140, 330, 14, ES_AUTOHSCROLL
    LTEXT       "Model:", 406, 22, 162, 100, 12
    EDITTEXT    IDC_TRANSLATE_MODEL, 128, 160, 330, 14, ES_AUTOHSCROLL
    LTEXT       "System Prompt (use ${TARGET_LANG} for language):", 407, 22, 186, 330, 12
    EDITTEXT    IDC_TRANSLATE_PROMPT, 22, 204, 438, 76, ES_MULTILINE | ES_AUTOVSCROLL | ES_WANTRETURN | WS_VSCROLL

    // ================================================================
    // General group
    // ================================================================
    GROUPBOX    "General", 303, 10, 300, 460, 100
    LTEXT       "Target Language:", 408, 22, 322, 100, 12
    EDITTEXT    IDC_TARGET_LANG, 128, 320, 180, 14, ES_AUTOHSCROLL
    LTEXT       "Offset (ms):", 409, 22, 344, 100, 12
    EDITTEXT    IDC_OFFSET_MS, 128, 342, 80, 14, ES_AUTOHSCROLL | ES_NUMBER
    CONTROL     "Enable Subtitle Processing", IDC_ENABLED, "Button",
                BS_AUTOCHECKBOX | WS_TABSTOP, 22, 370, 200, 14

    // ================================================================
    // Buttons
    // ================================================================
    DEFPUSHBUTTON "OK", IDOK, 170, 510, 85, 28
    PUSHBUTTON    "Cancel", IDCANCEL, 270, 510, 85, 28
END
